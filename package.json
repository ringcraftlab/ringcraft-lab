{
  "name": "ringcraft-lab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "icons": "node scripts/generate-pwa-icons.mjs",
    "pens:candidates": "node scripts/build-expanded-pen-candidates.mjs",
    "pens:amazon": "node scripts/build-amazon-pen-data.mjs",
    "pens:amazon-makers": "node scripts/build-amazon-pen-data.mjs --source none --queries scripts/amazon-maker-searches.json --maxResults 5 --maxPages 100 --delay 1200",
    "pens:csv": "node scripts/export-pen-report-csv.mjs",
    "pens:official-csv": "node scripts/export-official-pen-report-csv.mjs",
    "pens:image-review": "node scripts/export-pen-image-review.mjs",
    "pens:rakuten": "node scripts/build-rakuten-pen-data.mjs",
    "pens:rakuten-csv": "node scripts/export-pen-report-csv.mjs public/data/pens.rakuten-report.json public/data/pens.rakuten-report.csv",
    "pens:source-csv": "node scripts/export-pens-csv.mjs",
    "pens:trusted-csv": "node scripts/export-trusted-pen-models-csv.mjs",
    "prebuild": "node scripts/generate-pwa-icons.mjs",
    "predev": "node scripts/generate-pwa-icons.mjs",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.34.5",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
